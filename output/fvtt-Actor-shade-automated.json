    {
      "name": "Minion",
      "img": "icons/svg/mystery-man.svg",
      "type": "feat",
      "sort": 100000,
      "flags": {
        "dnd5e": {
          "migratedUses": 0
        },
        "dae": {
          "macro": {
            "name": "Minion",
            "img": "icons/svg/skull.svg",
            "type": "script",
            "scope": "global",
            "command": "if (args[0].macroPass !== \"preTargetDamageApplication\") return;\nconst workflow = args[0].workflow ?? MidiQOL.Workflow.getWorkflow(args[0].uuid);\nconst di = args[0].damageItem;\nif (!workflow || !di) return;\n\nconst token = canvas.tokens.get(di.tokenId) ?? canvas.tokens.placeables.find(t => t.actor?.uuid === di.actorUuid);\nconst actor = token?.actor;\nif (!actor) return;\n\nconst fromAttack = !!workflow.activity?.attack && (workflow.hitTargets?.has(token) || workflow.hitTargetsEC?.has(token));\nconst failedSave = !!workflow.activityHasSave && Array.from(workflow.failedSaves ?? []).some(t => t.actor?.uuid === di.actorUuid);\n\nconst setHP = (hp) => {\n  const oldHP = di.oldHP ?? actor.system.attributes.hp.value;\n  di.newHP = hp;\n  di.hpDamage = oldHP - hp;\n  di.totalDamage = di.hpDamage;\n  di.appliedDamage = di.hpDamage;\n  di.newTempHP = 0;\n};\n\nif (fromAttack || failedSave) {\n  setHP(0);  // minion drops to 0 from any attack or failed save\n} else {\n  const max = actor.system.attributes.hp.max ?? 0;\n  const incoming = Math.abs(Number(di.totalDamage ?? di.hpDamage ?? 0));\n  if (incoming >= max) setHP(0); else setHP(di.oldHP ?? actor.system.attributes.hp.value);\n}"
          }
        }
      },
      "effects": [
        {
          "_id": "ShadeMinion00001",
          "name": "Minion",
          "img": "icons/svg/skull.svg",
          "changes": [
            {
              "key": "flags.midi-qol.onUseMacroName",
              "mode": 0,
              "value": "[preTargetDamageApplication]ItemMacro.Minion",
              "priority": 20
            }
          ],
          "disabled": false,
          "duration": {},
          "description": "<p>Minion: damage from an attack or failed save reduces the shade to 0 HP. Damage from another effect kills the shade only if it equals or exceeds their HP maximum; otherwise they take no damage.</p>",
